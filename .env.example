# Copy this file to `.env` and fill in your values.
# `.env` is gitignored, so secrets stay out of the repo.
# Load it into your shell before running the app, e.g.:
#   set -a; source .env; set +a
#   NEW_RELIC_CONFIG_FILE=newrelic.ini newrelic-admin run-program python app.py

# --- New Relic ----------------------------------------------------------------

# Your INGEST - LICENSE key (NOT a user API key).
# Find it at: https://one.newrelic.com -> user menu -> API keys -> "INGEST - LICENSE"
NEW_RELIC_LICENSE_KEY=

# Optional: override the app name from newrelic.ini.
# Useful if you want separate entries per environment, e.g. "Tiny To-Do (Flask) [dev]".
# NEW_RELIC_APP_NAME=Tiny To-Do (Flask)

# Optional: pin the data region. Default is US.
# Set to "eu" if your New Relic account is in the EU data centre.
# NEW_RELIC_REGION=us
